# ===== Data artifacts (large, regenerable — not committed) =====
# The small curated Tatoeba corpus under data/raw/tatoeba/ IS committed; the
# big downloads and all processed/model artifacts are regenerated by the M2
# pipeline (scripts/build_corpus.py) and stay out of git.
/data/raw/kftt/
/data/raw/jesc/
/data/raw/jparacrawl/
/data/processed/*.jsonl
/data/processed/_m2_tmp/
/data/processed/_tok_sample/
/data/processed/tok*/
/data/models/

# ===== Model checkpoints (large, regenerable) =====
/checkpoints/

